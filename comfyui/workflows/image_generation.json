{
  "1": {
    "inputs": {
      "ckpt_name": "${ckpt_name:-flux1-dev.safetensors}",
      "lora_name": "${lora_name:-}",
      "lora_strength": "${lora_strength:-0.0}",
      "width": "${width:-1024}",
      "height": "${height:-1024}",
      "batch_size": 1
    },
    "class_type": "UNETLoader"
  },
  "2": {
    "inputs": {
      "text": "${prompt}",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode"
  },
  "3": {
    "inputs": {
      "text": "${negative_prompt:-}",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode"
  },
  "4": {
    "inputs": {
      "seed": "${seed:-123456789}",
      "steps": "${steps:-30}",
      "cfg": "${cfg_scale:-7.5}",
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler"
  },
  "5": {
    "inputs": {
      "width": "${width:-1024}",
      "height": "${height:-1024}",
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage"
  },
  "6": {
    "inputs": {
      "samples": ["4", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode"
  },
  "7": {
    "inputs": {
      "filename_prefix": "manjuflow_${project_id:-unknown}_scene_${scene_id:-0}",
      "images": ["6", 0]
    },
    "class_type": "SaveImage"
  },
  "8": {
    "inputs": {
      "control_net_name": "${controlnet:-openpose}",
      "image": "${control_image:-}"
    },
    "class_type": "ControlNetLoader"
  }
}
