{
  "1": {
    "inputs": {
      "base_model": "${base_model:-flux1-dev.safetensors}",
      "output_name": "${output_name:-character_lora}",
      "training_images": "${training_images}",
      "learning_rate": "${learning_rate:-0.0001}",
      "epochs": "${epochs:-100}",
      "batch_size": "${batch_size:-1}",
      "resolution": "${resolution:-512}"
    },
    "class_type": "LoRATrainer"
  },
  "2": {
    "inputs": {
      "lora_name": "${output_name:-character_lora}",
      "strength": 0.8,
      "clip_skip": -1
    },
    "class_type": "LoRALoader"
  },
  "3": {
    "inputs": {
      "ckpt_name": "${base_model:-flux1-dev.safetensors}",
      "lora": ["2", 0]
    },
    "class_type": "UNETLoader"
  },
  "4": {
    "inputs": {
      "text": "test prompt, ${character_name:-}",
      "clip": ["3", 1]
    },
    "class_type": "CLIPTextEncode"
  },
  "5": {
    "inputs": {
      "width": "${resolution:-512}",
      "height": "${resolution:-512}",
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage"
  },
  "6": {
    "inputs": {
      "seed": 123456789,
      "steps": 20,
      "cfg": 7.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1,
      "model": ["3", 0],
      "positive": ["4", 0],
      "negative": "",
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler"
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["3", 2]
    },
    "class_type": "VAEDecode"
  },
  "8": {
    "inputs": {
      "filename_prefix": "${output_name:-character_lora}_test",
      "images": ["7", 0]
    },
    "class_type": "SaveImage"
  }
}
