# PostgreSQL 配置
POSTGRES_USER=manju
POSTGRES_PASSWORD=manju123
POSTGRES_DB=manjuflow

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# MinIO 对象存储配置
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=manjuflow-assets

# ComfyUI 配置
COMFYUI_URL=http://localhost:8188
COMFYUI_CLIENT_ID=manjuflow-client

# FastAPI 配置
SECRET_KEY=your-secret-key-change-in-production-environment
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# 向量数据库配置 (Pinecone/Milvus)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX=manjuflow-assets

# LLM 配置
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# GPU 配置
GPU_ENABLED=true
GPU_MEMORY_FRACTION=0.8
